# Dotty — self-hosted StackChan robot assistant
# All environment variables for the unified docker-compose.yml.
# Copy to .env and fill in real values before deploying.

# --- General ---

# Container timezone (IANA format).
TZ=America/Chicago

# --- Admin API auth (X-Admin-Token) ---

# Shared secret protecting the /xiaozhi/admin/* routes (inject-text, say,
# set-state, play-asset, ...). `make setup` generates one if missing.
#
# Semantics: unset/empty = permissive mode — xiaozhi-server accepts admin
# calls with no auth. Set = xiaozhi-server requires a matching X-Admin-Token
# header on every admin call.
#
# Every service reads this SAME value: bridge, dotty-behaviour consumers,
# and the dotty-pi voice tools.
DOTTY_ADMIN_TOKEN=2123847f2c89ad0ae7e819ff998219b63f621b5f921b9bce937e9a5072d95618

# --- xiaozhi-esp32-server ---

# Active persona file under ./personas/ (loaded by the LLM provider).
PERSONA=default

# --- Kid Mode (child-safe guardrails) ---

# Set to "true" to enable child-safe rules: age-appropriate vocabulary,
# topic blocklist, self-harm redirect, jailbreak resistance.
# Set to "false" (default) for general-purpose assistant mode.
DOTTY_KID_MODE=false

# --- bridge.py (admin dashboard) ---

# FastAPI listen port for the dashboard service.
PORT=8081

# --- llama-swap ---

# (No user-facing env vars — configured via data/llama-swap.config.yaml)

# --- dotty-behaviour ---

# Model alias for narrative LLM calls (dreams, dance reflections, scene synth).
NARRATIVE_MODEL=think-big

# Timeout for narrative LLM calls (seconds).
NARRATIVE_TIMEOUT_SEC=90

# --- Perception: face greeter ---

# What the robot says when a face is freshly detected. Empty = silent greeting.
# FACE_GREET_TEXT=Hi!

# Minimum seconds between consecutive face-detected greetings.
# FACE_GREET_MIN_INTERVAL_SEC=30

# --- Purr-on-head-pet ---

# Path to the pre-rendered purr loop.
# PURR_AUDIO_PATH=bridge/assets/purr.opus
# PURR_COOLDOWN_SEC=5
# PURR_DURATION_SEC=2.0

# --- API keys (secrets — never commit real values) ---

# Required if using OpenAICompat LLM provider with a cloud endpoint.
# OPENROUTER_API_KEY=sk-or-v1-...

# Required if using the vision feature (camera -> VLM description).
# VISION_API_KEY=sk-or-v1-...

# --- Google Calendar integration (optional) ---

# CALENDAR_ID=abc123@group.calendar.google.com
# CALENDAR_POLL_SEC=900
# CALENDAR_PERSON_PREFIX_RE=^\s*\[(?P<person>[A-Za-z][A-Za-z0-9_-]{0,31})\]\s*(?P<rest>.+)$
# CALENDAR_HOUSEHOLD_BUCKET=_household

# --- Household registry ---

# HOUSEHOLD_YAML_PATH=/var/lib/dotty/shared/household.yaml

# --- Speaker resolver ---

# SPEAKER_STICKY_SEC=600
# SPEAKER_CALENDAR_WINDOW_MIN=30
# SPEAKER_PERCEPTION_WINDOW_SEC=30
# SPEAKER_ASK_THRESHOLD=0.5

# --- Proactive Greetings ---

# GREETER_ENABLED=true
# GREETER_USE_FACE_DETECTED=false
# GREETER_GREET_UNKNOWN=false
# GREETER_COOLDOWN_HOURS=4
# GREETER_PER_DAY_MAX=3
# GREETER_GREETING_MAX_WORDS=15

# --- Blind mode (low-light camera handling) ---

# DOTTY_BLIND_MODE=true
# DOTTY_BLIND_LAT=-27.47
# DOTTY_BLIND_LON=153.03
# DOTTY_BLIND_PHOTO_REPLY=It's too dark to see right now. Can you turn a light on?
